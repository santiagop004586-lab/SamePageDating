# SamePageDating Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===== REQUIRED =====

# Database
DATABASE_URL=postgresql://samepage:your_password_here@localhost:5432/samepage

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_32_chars_minimum

# CORS - Frontend URL
CORS_ORIGINS=["http://localhost:3000"]

# ===== APP MODE =====
# Options: "waitlist", "active_beta", "production"
APP_MODE=active_beta
ENVIRONMENT=development

# ===== OPTIONAL (but recommended) =====

# Email (Resend.com)
RESEND_API_KEY=re_your_api_key_here

# Geocoding (for profile location distance calculations)
MAPBOX_TOKEN=your_mapbox_token_here
GEOCODING_PROVIDER=mapbox

# Redis (for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# ===== PAYMENT (Stripe - Test Mode) =====
STRIPE_TEST_SECRET_KEY=sk_test_your_key_here
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_TEST_PRICE_ID=price_your_price_id_here
STRIPE_TEST_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook

# ===== PAYMENT (Stripe - Live Mode) =====
# Only needed for production
STRIPE_LIVE_SECRET_KEY=sk_live_your_key_here
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your_live_webhook
STRIPE_LIVE_PRICE_ID=price_your_live_price_id
STRIPE_LIVE_CONNECT_WEBHOOK_SECRET=whsec_your_live_connect_webhook

# ===== OAUTH =====
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===== API TOKENS (for future features) =====
ATTOM_API_KEY=
ESTATED_API_KEY=
REALTOR_API_KEY=
